<% layout("/layout/boilerplate")%>
<div class="row mt-3">
    <div class="col-7 offset-2"><br><br>
    <h2>Add new listing</h2>
    <form method="POST" action="/listings" novalidate class="needs-validation"  enctype="multipart/form-data">
        <div class="mb-3">
            <label for="title" class="form-lable">Title</label>
            <input type="text" 
            placeholder="write title" 
            name="listing[title]" 
            id="title" 
            class="form-control"
            required/>
            <div class="valid-feedback">Title looks good!</div>
        </div>


        <div class="mb-3">
            <label for="description" class="form-lable">Description</label>
            <textarea placeholder="write description" 
            name="listing[description]" 
            class="form-control" 
            id="description"
            required>
            </textarea>
        </div>

        <!-- <div class="mb-3">
            <label for="image" class="form-lable">Image</label>
            <input type="text" 
            placeholder="add your img url" 
            name="listing[image][url]" 
            class="form-control"
            id="image">
        </div> -->
        <div class="mb-3">
            <label for="image" class="form-lable">Upload Image</label>
            <input type="file"  
            name="listing[image]" 
            class="form-control"
            id="image">
            <!-- required -->
        </div>


        
        <div class="row">
        <div class="mb-3 col-md-4" >
            <label for="price" class="form-lable" >Price</label>
            <input type="number"
            placeholder="1200" 
            name="listing[price]" 
            class="form-control"
            required>
            <div class="invalid-feedback">Please enter valid price</div>
        </div>

        <div class="mb-3 col-md-8">
            <label for ="country" class="form-lable" >Country</label>
            <input type="text"
            placeholder="India" 
            name="listing[country]" 
            class="form-control"
            id="country"
            required>
            <div class="invalid-feedback">Please enter valid country</div>
        </div>
    </div>

        <div class="mb-3">
            <label for="location" class="form-lable" >Location</label>
            <input type="text"
            placeholder="Jaipur , Rajasthan" 
            name="listing[location]" 
            class="form-control"
            id="location"
            required>
            <div class="invalid-feedback">Please enter valid location</div>
        </div>

        
        <button class="btn btn-dark btn-style mt-3">Add</button>
        <br><br>
    
    </form>
    </div>
</div>
